# =============================================================================
# Biến môi trường — copy thành .env và điền giá trị thật (KHÔNG commit .env).
# Secret CHỈ ở env; giá trị không nhạy cảm nằm trong config/settings.yaml.
# Mọi biến đều có default an toàn cho dev — không đặt gì vẫn chạy offline được.
# =============================================================================

# --- Secrets (production) ---
# API key cho LLM planner (chỉ cần khi DETERMINISTIC_MODE=0)
ANTHROPIC_API_KEY=

# Auth của service: đặt 1 trong 2 thì API YÊU CẦU header tương ứng
# (Authorization: Bearer ... hoặc X-API-Key: ...); bỏ trống → mock mode.
TASCO_BEARER_TOKEN=
TASCO_API_KEY=

# --- Feature flags (override default trong config/settings.yaml) ---
# DETERMINISTIC_MODE=1 (mặc định): không gọi LLM, planner rule-based.
DETERMINISTIC_MODE=1
# Typo correction query-side (luật trong src/understanding/typo_fix.py).
TASCO_TYPO_FIX=1

# --- Data source (Phase 3) ---
# DATA_SOURCE=xlsx (mặc định) | postgres. Postgres cần DATABASE_URL + đã seed
# (docker compose up -d && make db-seed).
DATA_SOURCE=xlsx
# Connection string Postgres — default trong code khớp docker-compose dev
# (postgresql://tasco:tasco@localhost:5433/tasco). Production đặt URL thật ở đây.
DATABASE_URL=

# --- AWS Location verify (Phase 4b) ---
# API key của AWS Location (Geocode v2) — auth qua ?key=..., KHÔNG IAM/SigV4.
# TODO production: chuyển sang SigV4 (key lộ qua URL/log). Không đặt key →
# ingestion vẫn chạy, mọi record thành 'unverified' (flag không reject).
AWS_LOCATION_API_KEY=
# Region override (default lấy từ config/settings.yaml mục verify.aws_region)
AWS_DEFAULT_REGION=ap-southeast-2
